# === Neon Postgres ===
NEON_DATABASE_URL=postgresql+asyncpg://user:password@ep-xyz.us-east-2.aws.neon.tech/kisan_mitra?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xyz.us-east-2.aws.neon.tech/kisan_mitra?sslmode=require
DATABASE_URL_SYNC=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/kisan_mitra?sslmode=require

# === WhatsApp Cloud API ===
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_API_VERSION=v21.0

# === LLM Provider ===
# "groq" (cloud, free, fast — recommended for Railway)
# "ollama" (local, needs GPU/CPU — for self-hosted VPS)
LLM_PROVIDER=groq

# === Groq API (get free key at https://console.groq.com) ===
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# === Ollama (local dev / self-hosted fallback) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# === OpenWeatherMap ===
OPENWEATHER_API_KEY=your_api_key

# === Razorpay (for future premium features) ===
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# === App ===
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret
ADMIN_PASSWORD=change-this-admin-password
